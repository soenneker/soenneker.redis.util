<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Soenneker.Documents.Document" Version="4.0.2644" />
        <PackageReference Include="Soenneker.Facts.Manual" Version="4.0.174" />
        <PackageReference Include="Soenneker.Tests.HostedUnit" Version="4.0.13" />
        <PackageReference Include="Soenneker.Utils.Test" Version="4.0.315" />
        <PackageReference Include="TUnit" Version="1.37.24" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\Soenneker.Redis.Util\Soenneker.Redis.Util.csproj" />
    </ItemGroup>

    <ItemGroup>
        <None Update="appsettings.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

    <ItemGroup>
        <Content Include="testconfig.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>
</Project>
